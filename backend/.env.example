# Copy to .env for local dev. NEVER commit real secrets (§12).
ENVIRONMENT=dev
DATABASE_URL=sqlite:///./taxify.db
# In staging/prod use Postgres in an Indian region (ap-south-1):
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/taxify

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

DEFAULT_ASSESSMENT_YEAR=2026
